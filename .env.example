# Quorum Insights — Environment Configuration
# Copy this to .env and fill in your values:
#   cp .env.example .env

# ─── Required: PostHog Connection ───
POSTHOG_API_KEY=phx_your_personal_api_key_here
POSTHOG_PROJECT_ID=12345

# PostHog host (default: US Cloud)
# US Cloud: https://us.i.posthog.com
# EU Cloud: https://eu.i.posthog.com
# Self-hosted: https://posthog.yourcompany.com
POSTHOG_HOST=https://us.i.posthog.com

# ─── Required: LLM API Key ───
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ─── Optional: Delivery ───
# Slack incoming webhook for digest delivery
SLACK_WEBHOOK_URL=

# ─── Optional: Tuning ───
# Days of PostHog history to sync (default: 90)
LOOKBACK_DAYS=90

# Max insights per digest (default: 3)
MAX_INSIGHTS=3

# LLM model (default: claude-sonnet-4-20250514)
LLM_MODEL=claude-sonnet-4-20250514

# Prompt version (v1 or v2, default: v2)
PROMPT_VERSION=v2

# Tenant identifier (for multi-tenant setups)
TENANT_ID=default

# ─── ClickHouse (managed by docker compose) ───
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=insights
